#!/bin/sh

set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
WRAPPER_DIR="$SCRIPT_DIR/.mvn/wrapper"
WRAPPER_JAR="$WRAPPER_DIR/maven-wrapper.jar"
WRAPPER_PROPERTIES="$WRAPPER_DIR/maven-wrapper.properties"

if [ ! -f "$WRAPPER_JAR" ]; then
  WRAPPER_URL="https://repo.maven.apache.org/maven2/io/takari/maven-wrapper/0.5.6/maven-wrapper-0.5.6.jar"
  if [ -f "$WRAPPER_PROPERTIES" ]; then
    WRAPPER_URL_FROM_PROPERTIES="$(sed -n 's/^wrapperUrl=//p' "$WRAPPER_PROPERTIES" | head -n 1)"
    if [ -n "$WRAPPER_URL_FROM_PROPERTIES" ]; then
      WRAPPER_URL="$WRAPPER_URL_FROM_PROPERTIES"
    fi
  fi

  mkdir -p "$WRAPPER_DIR"

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$WRAPPER_URL" -o "$WRAPPER_JAR"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$WRAPPER_URL" -O "$WRAPPER_JAR"
  else
    echo "No se encontró curl ni wget para descargar Maven Wrapper." >&2
    exit 1
  fi
fi

JAVA_CMD="${JAVA_HOME:+$JAVA_HOME/bin/java}"
if [ -z "${JAVA_CMD:-}" ]; then
  JAVA_CMD="java"
fi

exec "$JAVA_CMD" -Dmaven.multiModuleProjectDirectory="$SCRIPT_DIR" -classpath "$WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"